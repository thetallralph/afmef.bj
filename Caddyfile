:80 {
	# /admin redirige vers le dashboard PocketBase
	redir /admin /_/ 302

	# Dashboard PocketBase
	@pbui {
		path /_/*
		path /_
	}
	reverse_proxy @pbui pocketbase:8090

	# API PocketBase (tout /api/ sauf /api/auth/ qui est SvelteKit)
	@pbapi {
		path /api/*
		not path /api/auth/*
	}
	reverse_proxy @pbapi pocketbase:8090

	# Tout le reste vers SvelteKit
	reverse_proxy app:3000
}
