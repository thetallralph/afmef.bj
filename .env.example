# URL publique PocketBase (côté client/navigateur)
# En dev : PocketBase direct
# En prod : même domaine, Caddy route vers PocketBase
PUBLIC_POCKETBASE_URL=http://localhost:8090

# URL interne PocketBase (côté serveur SvelteKit uniquement)
# En dev : même que PUBLIC_POCKETBASE_URL
# En prod : URL Docker interne (http://pocketbase:8090)
POCKETBASE_URL=http://localhost:8090

# KKiaPay - Paiement en ligne
PUBLIC_KKIAPAY_API_KEY=your_kkiapay_public_key

# Guide interne (/guide)
GUIDE_PASSWORD=afmef2024

# URL publique de l'application (utilisée dans les liens des emails)
PUBLIC_APP_URL=https://afmef.bj

# SMTP — envoi des emails (rappels de cotisation, validation de compte)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=AFMEF <no-reply@afmef.bj>
